# Postgres (Neon free tier)
DATABASE_URL=postgresql+asyncpg://user:password@host/loresmith

# LLM
GEMINI_API_KEY=your-gemini-api-key-here
LLM_BACKEND=gemini          # gemini | ollama | auto

# Embeddings
EMBEDDING_BACKEND=local     # local (bge-base-en-v1.5, default) | gemini (requires GEMINI_API_KEY)
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RETRIEVAL_TOP_K_PER_METHOD=10   # BM25 and dense each retrieve this many candidates
RETRIEVAL_TOP_K_FINAL=5         # RRF fuses candidates down to this many passages

# Ollama (optional local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_STRONG_MODEL=qwen2.5:7b
OLLAMA_FAST_MODEL=qwen2.5:3b

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# CORS (JSON array; add staging/preview origins as needed)
# CORS_ORIGINS='["http://localhost:3000","https://loresmith.vercel.app"]'

# Security
INGEST_TOKEN=change-me-before-deploy
ANON_SESSION_COOKIE_NAME=loresmith_anon_session
ANON_SESSION_COOKIE_MAX_AGE_SECONDS=7776000
# For split frontend/backend deployments, set:
# ANON_SESSION_COOKIE_SECURE=true
# ANON_SESSION_COOKIE_SAMESITE=none
ANON_SESSION_COOKIE_SECURE=false
ANON_SESSION_COOKIE_SAMESITE=lax
